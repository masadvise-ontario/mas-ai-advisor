# mas-ai-advisor environment variables
# Copy to .env.local for development; NEVER commit real secrets.

# Postgres connection to MAS database.
# Host:     mas-n8n-postgress-db.postgres.database.azure.com
# Database: mas
# Role:     mas_ai_advisor (scoped grants on mas_journey_* tables only — NOT the brian admin)
# Password: stored in Azure Key Vault `mas-n8n-kv` under secret `Azure-PG-Mas-Advisor-Password`.
#           In Vercel, pull the value once and paste into the env var; rotate quarterly.
MAS_ADVISOR_DATABASE_URL=postgres://mas_ai_advisor:<password>@mas-n8n-postgress-db.postgres.database.azure.com:5432/mas?sslmode=require

# API key for the three Advisor endpoints (rotated quarterly).
# Generate with: openssl rand -hex 32
MAS_ADVISOR_API_KEY=replace-with-strong-random-string

# Anthropic API key for running the probe-set harness (pnpm test:probes).
# Only needed locally for prompt iteration; not used in Vercel deployment.
# Set a monthly spend cap on the key in console.anthropic.com as a safety net.
ANTHROPIC_API_KEY=sk-ant-...

# --------------------------------------------------------------------------
# OAuth provider (PR #13) — Auth.js + in-repo OAuth 2.1 provider for /api/mcp
# --------------------------------------------------------------------------

# Auth.js (NextAuth v5) — sign-in flow for the OAuth /authorize endpoint.
# AUTH_SECRET signs the Auth.js session JWT (separate concern from
# MAS_ADVISOR_OAUTH_JWT_PRIVATE_KEY below, which signs OAuth access tokens).
# Generate: openssl rand -base64 32
AUTH_SECRET=replace-with-strong-random-string

# Optional: explicit base URL for Auth.js (only needed for local dev — Vercel
# auto-detects via VERCEL_URL in production).
AUTH_URL=http://localhost:3000

# Upstream identity providers. Configure both at the providers' consoles
# with callback URL `<AUTH_URL>/api/auth/callback/{google,github}`.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# OAuth provider signing keys. RS256 keypair. The PRIVATE key signs access
# tokens issued by /oauth/token; the PUBLIC key is published at
# /.well-known/jwks.json for downstream verification.
# Generate (one-time):
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out priv.pem
#   openssl pkey -in priv.pem -pubout -out pub.pem
# Then base64-encode (single-line) into the env vars below:
#   base64 -w0 priv.pem; echo
#   base64 -w0 pub.pem ; echo
# Rotate annually; both old and new public keys can be advertised in JWKS
# during a rotation window.
MAS_ADVISOR_OAUTH_JWT_PRIVATE_KEY=
MAS_ADVISOR_OAUTH_JWT_PUBLIC_KEY=

# Public issuer URL — the base URL of the Advisor API as seen by OAuth
# clients (claude.ai, etc.). Used as the JWT `iss` claim and in the
# .well-known/* discovery metadata. Must match the deployed Vercel URL
# (or http://localhost:3000 for local dev).
MAS_ADVISOR_OAUTH_ISSUER=http://localhost:3000
